                      "id":  "fca6caea-50f0-44a8-9869-501d0f8318b9",
                      "name":  "Poll Events",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.2,
                      "position":  [
                                       840,
                                       300
                                   ]
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const response = $input.first().json;\n\nfunction severityFor(event) {\n  if (event?.data?.decision === \u0027denied\u0027) return \u0027critical\u0027;\n  if (event?.type === \u0027LockerPolicyDecisionEvent\u0027 \u0026\u0026 event?.data?.reasonCode === \u0027HARD_BLOCKED\u0027) return \u0027critical\u0027;\n  if (event?.type === \u0027StaffAuditEvent\u0027 \u0026\u0026 event?.data?.outcome === \u0027blocked\u0027) return \u0027critical\u0027;\n\n  if ([\u0027LockerAccessEvent\u0027, \u0027RoomAccessEvent\u0027, \u0027AccessAttempt\u0027].includes(event?.type)) return \u0027high\u0027;\n  if ([\u0027CleaningTask\u0027, \u0027RoomBooking\u0027, \u0027PresenceEvent\u0027].includes(event?.type)) return \u0027medium\u0027;\n\n  return \u0027low\u0027;\n}\n\nconst config = $(\u0027Config\u0027).first().json;\nconst events = Array.isArray(response?.events) ? response.events : [];\nconst polledAt = response?.lastPolledAt || new Date().toISOString();\n\nreturn events.map((event) =\u003e {\n  const data = event?.data || {};\n  const severity = severityFor(event);\n\n  const title = `${event.type} - ${data.memberId || data.actorStaffUserId || \u0027System\u0027}`.slice(0, 200);\n  const status = String(data.decision || data.status || data.outcome || \u0027pending\u0027);\n  const memberId = data.memberId ? String(data.memberId) : \u0027\u0027;\n  const lockerId = data.lockerId ? String(data.lockerId) : \u0027\u0027;\n  const roomId = data.roomId ? String(data.roomId) : \u0027\u0027;\n  const decision = data.decision ? String(data.decision) : \u0027\u0027;\n  const denialReason = String(data.denialReasonCode || data.reasonCode || \u0027\u0027);\n  const rawData = JSON.stringify(data).slice(0, 1800);\n\n  return {\n    json: {\n      ...event,\n      severity,\n      polledAt,\n      opsEmail: config.opsEmail,\n      notionPayload: {\n        parent: {\n          database_id: config.notionDatabaseId\n        },\n        properties: {\n          Title: {\n            title: [{ text: { content: title } }]\n          },\n          \u0027Event Type\u0027: {\n            select: { name: String(event.type) }\n          },\n          Status: {\n            select: { name: status }\n          },\n          Severity: {\n            select: { name: severity }\n          },\n          Timestamp: {\n            date: { start: String(event.occurredAt) }\n          },\n          \u0027Member ID\u0027: {\n            rich_text: memberId ? [{ text: { content: memberId } }] : []\n          },\n          \u0027Locker ID\u0027: {\n            rich_text: lockerId ? [{ text: { content: lockerId } }] : []\n          },\n          \u0027Room ID\u0027: {\n            rich_text: roomId ? [{ text: { content: roomId } }] : []\n          },\n          Decision: {\n            rich_text: decision ? [{ text: { content: decision } }] : []\n          },\n          \u0027Denial Reason\u0027: {\n            rich_text: denialReason ? [{ text: { content: denialReason } }] : []\n          },\n          \u0027Raw Data\u0027: {\n            rich_text: rawData ? [{ text: { content: rawData } }] : []\n          },\n          \u0027Polled At\u0027: {\n            date: { start: String(polledAt) }\n          }\n        }\n      }\n    }\n  };\n});"
                                     },
