# Cloudflared API Host Setup (.env template)
# Store this on your Linux API host at /root/.env or source it before starting cloudflared

# Cloudflare account credentials
CLOUDFLARED_TUNNEL_ID=3a12c58b-3dad-4cfc-af2b-2b69a7c36ab3

# Location of tunnel credentials file (on API host)
CLOUDFLARED_CREDENTIALS_FILE=/root/.cloudflared/${CLOUDFLARED_TUNNEL_ID}.json

# Service configuration
CLOUDFLARED_SERVICE_NAME=cloudflared
CLOUDFLARED_CONFIG_PATH=/root/.cloudflared/config.yml

# Tunnel healthcheck URL (must match config.yml route)
CLOUDFLARED_HEALTH_URL=https://api.aosanctuary.com/v1/health

# ---------------------------------------------------------------------------
# Ops integration vars (mirrors root .env — required by scripts/ops.ps1 and
# the /v1/ops/snapshot infra-health checks)
# ---------------------------------------------------------------------------
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_TUNNEL_URL=https://api.aosanctuary.com/v1/health
