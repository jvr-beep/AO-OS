# AO-OS Example Environment Variables
# Copy to .env and fill in your real values — never commit .env

# ---------------------------------------------------------------------------
# SwaggerHub
# ---------------------------------------------------------------------------
SWAGGERHUB_TOKEN=

# ---------------------------------------------------------------------------
# Cloudflare
# ---------------------------------------------------------------------------
# Tunnel credentials — run `cloudflared tunnel token ao-os-api` to obtain
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# Public URL served through the tunnel (used for health checks)
CLOUDFLARE_TUNNEL_URL=https://api.aosanctuary.com/v1/health

# ---------------------------------------------------------------------------
# Vercel (frontend deployment)
# ---------------------------------------------------------------------------
# Create a token at https://vercel.com/account/tokens
VERCEL_TOKEN=
# Found in Project Settings > General
VERCEL_PROJECT_ID=
# Your Vercel team/org ID (leave blank for personal accounts)
VERCEL_ORG_ID=

# ---------------------------------------------------------------------------
# GCP (VM management)
# ---------------------------------------------------------------------------
GCP_PROJECT=
GCP_ZONE=us-central1-a
GCP_INSTANCE=

# ---------------------------------------------------------------------------
# Local API (scripts/ops.ps1 status check)
# ---------------------------------------------------------------------------
AO_API_BASE=http://localhost:4000
