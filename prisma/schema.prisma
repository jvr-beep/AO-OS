generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberStatus {
  pending
  active
  suspended
  banned
}

enum MemberType {
  anonymous
  registered
}

enum AuthTokenType {
  password_reset
  email_verify
  invite_set_password
}

enum ExternalAuthProvider {
  google
}

enum AuthMethod {
  password
  google
  admin_invite
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  paused
  cancelled
}

enum BillingInterval {
  day
  week
  month
  year
}

enum PaymentMethodStatus {
  active
  inactive
  revoked
}

enum WristbandStatus {
  unassigned
  pending_activation
  suspended
  replaced

  inventory
  assigned
  active
  lost
  stolen
  damaged
  retired
}

enum AccessDecision {
  allowed
  denied
  error
}

enum VisitStatus {
  checked_in
  checked_out
}

enum StaffRole {
  front_desk
  operations
  admin
}

enum WristbandTransactionType {
  purchase
  adjustment
  refund
}

enum WristbandTransactionStatus {
  pending
  completed
  failed
}

enum MemberAccountEntryType {
  charge
  credit
  refund
  payment
}

enum MemberAccountEntryStatus {
  posted
  voided
}

enum MemberAccountSourceType {
  wristband_transaction
  manual_adjustment
  manual_payment
  refund
  membership
  locker_fee
}

enum LockerStatus {
  available
  reserved
  occupied
  cleaning
  maintenance
  offline
  forced_open

  assigned
  out_of_service
}

enum LockerAssignmentMode {
  day_use_shared
  assigned
  premium
  staff_override
}

enum LockerPolicyDecision {
  allow
  deny
}

enum LockerAccessDecision {
  allowed
  denied
}

enum LockerAccessEventType {
  unlock
  lock
  open
  close
}

enum FloorPlanAreaType {
  room
  corridor
  entry
  service
  bath
  lounge
  locker_bank
}

enum RoomType {
  private
  premium_private
  retreat
  ritual
  accessible
  couples_reserved_future
}

enum RoomPrivacyLevel {
  standard
  high
  premium
}

enum RoomStatus {
  available
  booked
  occupied
  cleaning
  out_of_service
}

enum RoomBookingType {
  restore
  release
  retreat
}

enum RoomBookingStatus {
  reserved
  checked_in
  checked_out
  expired
  cancelled
  no_show
  waitlisted
}

enum RoomBookingSourceType {
  membership_credit
  upgrade_credit
  one_time_purchase
  manual_staff
  package_credit
}

enum RoomAccessDecision {
  allowed
  denied
  error
}

enum RoomAccessEventType {
  unlock
  lock
  open
  close
  check_in_gate
  check_out_gate
}

enum RoomAccessSourceType {
  wristband_reader
  staff_console
  system
}

enum CleaningTaskType {
  turnover
  deep_clean
  inspection
}

enum CleaningTaskStatus {
  open
  in_progress
  completed
  cancelled
}

enum AccessNodeType {
  entry
  reader
  camera
  service_point
}

enum DeviceType {
  door_controller
  reader
  camera
  environmental
}

enum DeviceStatus {
  online
  offline
  degraded
}

model Member {
  id                 String       @id @default(uuid())
  publicMemberNumber String       @unique
  type               MemberType   @default(registered)
  email              String?      @unique
  emailVerifiedAt    DateTime?    @map("email_verified_at")
  firstName          String?
  lastName           String?
  alias              String?
  displayName        String?
  phone              String?
  status             MemberStatus @default(pending)
  createdByStaffId   String?      @map("created_by_staff_id")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  profile                    MemberProfile?
  authAccount                AuthAccount?
  authTokens                 AuthToken[]
  externalAuths              ExternalAuthIdentity[]
  authSessions               AuthSession[]
  authEvents                 AuthEvent[]
  subscriptions              MembershipSubscription[]
  paymentMethods             PaymentMethodToken[]
  wristbandAssignments       WristbandAssignment[]
  visitSessions              VisitSession[]
  accessAttempts             AccessAttempt[]
  accessGrants               MemberAccessGrant[]
  accessOverrides            MemberAccessOverride[]
  presenceEvents             PresenceEvent[]
  wristbandTransactions      WristbandTransaction[]
  lockerAssignments          LockerAssignment[]
  lockerAccessEvents         LockerAccessEvent[]
  lockerPolicyDecisionEvents LockerPolicyDecisionEvent[]
  accountEntries             MemberAccountEntry[]
  roomBookings               RoomBooking[]
  roomAccessEvents           RoomAccessEvent[]
}

model MemberProfile {
  id                    String   @id @default(uuid())
  memberId              String   @unique
  preferredName         String?
  pronouns              String?
  emergencyContactName  String?
  emergencyContactPhone String?
  marketingOptInEmail   Boolean  @default(false)
  marketingOptInSms     Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model ExternalAuthIdentity {
  id              String               @id @default(uuid())
  memberId        String               @map("member_id")
  provider        ExternalAuthProvider
  providerSubject String               @map("provider_subject")
  emailAtProvider String?              @map("email_at_provider")
  profileJson     Json?                @map("profile_json")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([provider, providerSubject])
  @@index([memberId])
  @@map("external_auth_identities")
}

model AuthAccount {
  id             String    @id @default(uuid())
  memberId       String    @unique @map("member_id")
  passwordHash   String    @map("password_hash")
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@map("auth_accounts")
}

model AuthToken {
  id         String        @id @default(uuid())
  memberId   String        @map("member_id")
  type       AuthTokenType
  tokenHash  String        @map("token_hash")
  expiresAt  DateTime      @map("expires_at")
  consumedAt DateTime?     @map("consumed_at")
  createdAt  DateTime      @default(now()) @map("created_at")

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([memberId, type, consumedAt])
  @@map("auth_tokens")
}

model AuthSession {
  id               String     @id @default(uuid())
  memberId         String     @map("member_id")
  authMethod       AuthMethod @map("auth_method")
  refreshTokenHash String?    @map("refresh_token_hash")
  ipAddress        String?    @map("ip_address")
  userAgent        String?    @map("user_agent")
  expiresAt        DateTime   @map("expires_at")
  revokedAt        DateTime?  @map("revoked_at")
  createdAt        DateTime   @default(now()) @map("created_at")

  member     Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  authEvents AuthEvent[]

  @@index([memberId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model AuthEvent {
  id                String      @id @default(uuid())
  memberId          String?     @map("member_id")
  sessionId         String?     @map("session_id")
  eventType         String      @map("event_type")
  authMethod        AuthMethod? @map("auth_method")
  outcome           String
  failureReasonCode String?     @map("failure_reason_code")
  attemptedEmail    String?     @map("attempted_email")
  ipAddress         String?     @map("ip_address")
  userAgent         String?     @map("user_agent")
  metadataJson      Json?       @map("metadata_json")
  occurredAt        DateTime    @default(now()) @map("occurred_at")
  createdAt         DateTime    @default(now()) @map("created_at")

  member  Member?      @relation(fields: [memberId], references: [id], onDelete: SetNull)
  session AuthSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([occurredAt])
  @@index([eventType, occurredAt])
  @@index([memberId, occurredAt])
  @@map("auth_events")
}

model StaffUser {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  fullName     String
  role         StaffRole @default(front_desk)
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assignedCleaningTasks CleaningTask[]
}

model MembershipPlan {
  id              String          @id @default(uuid())
  code            String          @unique
  name            String
  description     String?
  tierRank        Int
  billingInterval BillingInterval
  priceAmount     Decimal         @db.Decimal(10, 2)
  currency        String
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  subscriptions MembershipSubscription[]
  entitlements  MembershipEntitlement[]
}

model MembershipSubscription {
  id                        String             @id @default(uuid())
  memberId                  String
  membershipPlanId          String
  billingProvider           String
  billingProviderCustomerId String?
  status                    SubscriptionStatus
  cancelAtPeriodEnd         Boolean            @default(false)
  startDate                 DateTime
  currentPeriodStart        DateTime?
  currentPeriodEnd          DateTime?
  pausedAt                  DateTime?
  resumedAt                 DateTime?
  createdAt                 DateTime           @default(now())
  updatedAt                 DateTime           @updatedAt

  member         Member         @relation(fields: [memberId], references: [id], onDelete: Cascade)
  membershipPlan MembershipPlan @relation(fields: [membershipPlanId], references: [id])
}

model MembershipEntitlement {
  id               String   @id @default(uuid())
  membershipPlanId String
  entitlementCode  String
  entitlementType  String
  valueJson        Json
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())

  membershipPlan MembershipPlan @relation(fields: [membershipPlanId], references: [id], onDelete: Cascade)
}

model PaymentMethodToken {
  id                      String              @id @default(uuid())
  memberId                String
  provider                String
  providerCustomerId      String?
  providerPaymentMethodId String
  brand                   String?
  last4                   String?
  expMonth                Int?
  expYear                 Int?
  isDefault               Boolean             @default(false)
  status                  PaymentMethodStatus @default(active)
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model Location {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now())

  facility      Facility?
  wristbands    Wristband[]
  accessPoints  AccessPoint[]
  visitSessions VisitSession[]
  lockers       Locker[]
  floorPlans    FloorPlan[]
  rooms         Room[]
}

model Facility {
  id         String   @id @default(uuid())
  code       String   @unique
  name       String
  locationId String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  location Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  floors   Floor[]
}

model Wristband {
  id                      String          @id @default(uuid())
  uid                     String          @unique
  locationId              String?
  homeLocationId          String?
  status                  WristbandStatus @default(inventory)
  globalAccessFlag        Boolean         @default(false)
  issuedAt                DateTime        @default(now())
  activatedAt             DateTime?
  suspendedAt             DateTime?
  replacedFromWristbandId String?
  lastSeenLocationId      String?
  lastSeenAt              DateTime?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  location              Location?              @relation(fields: [locationId], references: [id])
  assignments           WristbandAssignment[]
  accessAttempts        AccessAttempt[]
  wristbandTransactions WristbandTransaction[]
  lockerAccessEvents    LockerAccessEvent[]
  roomAccessEvents      RoomAccessEvent[]
  // New guest-visit domain relations
  wristbandLinks        WristbandLink[]
  accessPermissions     AccessPermission[]
  guestAccessEvents     GuestAccessEvent[]
  systemExceptions      SystemException[]
}

model WristbandAssignment {
  id                    String    @id @default(uuid())
  wristbandId           String
  memberId              String
  assignedByStaffUserId String?
  assignedAt            DateTime  @default(now())
  unassignedAt          DateTime?
  unassignedReason      String?
  active                Boolean   @default(true)

  wristband         Wristband          @relation(fields: [wristbandId], references: [id], onDelete: Cascade)
  member            Member             @relation(fields: [memberId], references: [id], onDelete: Cascade)
  visitSessions     VisitSession[]
  lockerAssignments LockerAssignment[]
}

model WristbandTransaction {
  id              String                     @id @default(uuid())
  memberId        String
  wristbandId     String
  transactionType WristbandTransactionType
  merchantType    String
  amount          Decimal                    @db.Decimal(10, 2)
  currency        String
  description     String?
  sourceReference String?
  status          WristbandTransactionStatus @default(completed)
  occurredAt      DateTime
  createdAt       DateTime                   @default(now())

  member    Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  wristband Wristband @relation(fields: [wristbandId], references: [id], onDelete: Cascade)

  @@index([occurredAt])
  @@index([memberId])
}

model MemberAccountEntry {
  id              String                   @id @default(uuid())
  memberId        String
  entryType       MemberAccountEntryType
  amount          Decimal                  @db.Decimal(10, 2)
  currency        String
  description     String?
  status          MemberAccountEntryStatus @default(posted)
  sourceType      MemberAccountSourceType
  sourceReference String?
  occurredAt      DateTime
  createdAt       DateTime                 @default(now())

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, occurredAt])
  @@index([memberId, status])
}

model Locker {
  id                  String       @id @default(uuid())
  code                String       @unique
  vendorLockId        String?
  locationId          String?
  zoneId              String?
  bankId              String?
  wallId              String?
  lockerLabel         String?
  lockerSize          String?
  lockerType          String?
  isAccessible        Boolean      @default(false)
  isWetAreaRated      Boolean      @default(false)
  hasPower            Boolean      @default(false)
  tierClass           String?
  status              LockerStatus @default(available)
  supportsDayUse      Boolean      @default(true)
  supportsAssignedUse Boolean      @default(true)
  active              Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  location             Location?                   @relation(fields: [locationId], references: [id])
  assignments          LockerAssignment[]
  accessEvents         LockerAccessEvent[]
  policyDecisionEvents LockerPolicyDecisionEvent[]
}

model LockerAssignment {
  id                    String               @id @default(uuid())
  lockerId              String
  memberId              String
  visitSessionId        String?
  wristbandAssignmentId String?
  assignmentMode        LockerAssignmentMode @default(assigned)
  policySnapshot        Json?
  assignedByStaffUserId String?
  assignedAt            DateTime             @default(now())
  unassignedAt          DateTime?
  unassignedReason      String?
  active                Boolean              @default(true)

  locker              Locker               @relation(fields: [lockerId], references: [id], onDelete: Cascade)
  member              Member               @relation(fields: [memberId], references: [id], onDelete: Cascade)
  visitSession        VisitSession?        @relation(fields: [visitSessionId], references: [id], onDelete: SetNull)
  wristbandAssignment WristbandAssignment? @relation(fields: [wristbandAssignmentId], references: [id], onDelete: SetNull)
  accessEvents        LockerAccessEvent[]

  @@index([lockerId, active])
  @@index([memberId])
}

model LockerAccessEvent {
  id                 String                @id @default(uuid())
  memberId           String?
  lockerId           String
  wristbandId        String?
  lockerAssignmentId String?
  decision           LockerAccessDecision
  denialReasonCode   String?
  eventType          LockerAccessEventType
  occurredAt         DateTime
  sourceReference    String?
  rawPayloadJson     Json?
  createdAt          DateTime              @default(now())

  member           Member?           @relation(fields: [memberId], references: [id], onDelete: SetNull)
  locker           Locker            @relation(fields: [lockerId], references: [id], onDelete: Cascade)
  wristband        Wristband?        @relation(fields: [wristbandId], references: [id], onDelete: SetNull)
  lockerAssignment LockerAssignment? @relation(fields: [lockerAssignmentId], references: [id], onDelete: SetNull)

  @@index([occurredAt])
  @@index([memberId])
}

model LockerPolicyDecisionEvent {
  id                 String               @id @default(uuid())
  memberId           String?
  lockerId           String?
  visitSessionId     String?
  staffUserId        String?
  siteId             String?
  requestedZoneId    String?
  requestedLockerId  String?
  assignmentMode     LockerAssignmentMode
  decision           LockerPolicyDecision
  reasonCode         String
  eligibleLockerIds  String[]
  chosenLockerId     String?
  inputSnapshotJson  Json
  outputSnapshotJson Json
  correlationId      String?
  createdAt          DateTime             @default(now())

  member       Member?       @relation(fields: [memberId], references: [id], onDelete: SetNull)
  locker       Locker?       @relation(fields: [lockerId], references: [id], onDelete: SetNull)
  visitSession VisitSession? @relation(fields: [visitSessionId], references: [id], onDelete: SetNull)

  @@index([memberId, createdAt])
  @@index([lockerId, createdAt])
  @@index([visitSessionId, createdAt])
  @@index([siteId, createdAt])
}

model AccessZone {
  id              String   @id @default(uuid())
  code            String   @unique
  name            String
  requiresBooking Boolean  @default(false)
  createdAt       DateTime @default(now())

  accessPoints    AccessPoint[]
  accessAttempts  AccessAttempt[]
  accessGrants    MemberAccessGrant[]
  accessOverrides MemberAccessOverride[]
  bookings        Booking[]
  presenceEvents  PresenceEvent[]
}

model AccessPoint {
  id           String   @id @default(uuid())
  locationId   String
  accessZoneId String
  code         String   @unique
  name         String
  createdAt    DateTime @default(now())

  location       Location        @relation(fields: [locationId], references: [id])
  accessZone     AccessZone      @relation(fields: [accessZoneId], references: [id])
  accessAttempts AccessAttempt[]
}

model MemberAccessGrant {
  id           String    @id @default(uuid())
  memberId     String
  accessZoneId String
  validFrom    DateTime?
  validUntil   DateTime?
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())

  member     Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  accessZone AccessZone @relation(fields: [accessZoneId], references: [id], onDelete: Cascade)
}

model MemberAccessOverride {
  id                   String    @id @default(uuid())
  memberId             String
  accessZoneId         String
  action               String
  reason               String?
  grantedByStaffUserId String?
  validFrom            DateTime?
  validUntil           DateTime?
  createdAt            DateTime  @default(now())

  member     Member     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  accessZone AccessZone @relation(fields: [accessZoneId], references: [id], onDelete: Cascade)
}

model AccessAttempt {
  id               String         @id @default(uuid())
  memberId         String?
  wristbandId      String?
  accessPointId    String
  accessZoneId     String
  attemptSource    String?
  decision         AccessDecision
  denialReasonCode String?
  occurredAt       DateTime

  member      Member?     @relation(fields: [memberId], references: [id], onDelete: SetNull)
  wristband   Wristband?  @relation(fields: [wristbandId], references: [id], onDelete: SetNull)
  accessPoint AccessPoint @relation(fields: [accessPointId], references: [id])
  accessZone  AccessZone  @relation(fields: [accessZoneId], references: [id])
}

model VisitSession {
  id                    String      @id @default(uuid())
  memberId              String
  locationId            String
  wristbandAssignmentId String?
  checkInAt             DateTime
  checkOutAt            DateTime?
  status                VisitStatus
  createdAt             DateTime    @default(now())

  member                     Member                      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  location                   Location                    @relation(fields: [locationId], references: [id])
  wristbandAssignment        WristbandAssignment?        @relation(fields: [wristbandAssignmentId], references: [id])
  presenceEvents             PresenceEvent[]
  lockerAssignments          LockerAssignment[]
  lockerPolicyDecisionEvents LockerPolicyDecisionEvent[]
}

model PresenceEvent {
  id              String   @id @default(uuid())
  visitSessionId  String
  memberId        String
  accessZoneId    String?
  eventType       String
  sourceType      String?
  sourceReference String?
  occurredAt      DateTime @default(now())
  payloadJson     Json?

  visitSession VisitSession @relation(fields: [visitSessionId], references: [id], onDelete: Cascade)
  member       Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  accessZone   AccessZone?  @relation(fields: [accessZoneId], references: [id], onDelete: SetNull)
}

model Booking {
  id           String   @id @default(uuid())
  memberId     String
  accessZoneId String
  startsAt     DateTime
  endsAt       DateTime
  status       String
  createdAt    DateTime @default(now())

  accessZone AccessZone @relation(fields: [accessZoneId], references: [id])
}

model FloorPlan {
  id         String   @id @default(uuid())
  locationId String
  name       String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  location Location        @relation(fields: [locationId], references: [id], onDelete: Cascade)
  floor    Floor?
  areas    FloorPlanArea[]

  @@index([locationId, active])
}

model Floor {
  id          String   @id @default(uuid())
  facilityId  String
  floorPlanId String?  @unique
  code        String
  name        String
  levelIndex  Int
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  facility    Facility     @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  floorPlan   FloorPlan?   @relation(fields: [floorPlanId], references: [id], onDelete: SetNull)
  zones       Zone[]
  accessNodes AccessNode[]
  devices     Device[]

  @@unique([facilityId, code])
  @@index([facilityId, active, levelIndex])
}

model FloorPlanArea {
  id          String            @id @default(uuid())
  floorPlanId String
  code        String
  name        String
  areaType    FloorPlanAreaType
  x           Decimal           @db.Decimal(10, 2)
  y           Decimal           @db.Decimal(10, 2)
  width       Decimal           @db.Decimal(10, 2)
  height      Decimal           @db.Decimal(10, 2)
  active      Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  floorPlan FloorPlan @relation(fields: [floorPlanId], references: [id], onDelete: Cascade)
  room      Room?
  zone      Zone?

  @@unique([floorPlanId, code])
  @@index([floorPlanId, active])
}

model Zone {
  id              String            @id @default(uuid())
  floorId         String
  floorPlanAreaId String?           @unique
  roomId          String?           @unique
  code            String
  name            String
  zoneType        FloorPlanAreaType
  polygonJson     Json
  active          Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  floor         Floor          @relation(fields: [floorId], references: [id], onDelete: Cascade)
  floorPlanArea FloorPlanArea? @relation(fields: [floorPlanAreaId], references: [id], onDelete: SetNull)
  room          Room?          @relation(fields: [roomId], references: [id], onDelete: SetNull)
  accessNodes   AccessNode[]
  devices       Device[]

  @@unique([floorId, code])
  @@index([floorId, active])
}

model AccessNode {
  id           String         @id @default(uuid())
  floorId      String
  zoneId       String?
  code         String         @unique
  name         String
  nodeType     AccessNodeType
  x            Decimal        @db.Decimal(10, 2)
  y            Decimal        @db.Decimal(10, 2)
  status       DeviceStatus   @default(online)
  active       Boolean        @default(true)
  metadataJson Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  floor Floor @relation(fields: [floorId], references: [id], onDelete: Cascade)
  zone  Zone? @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  @@index([floorId, active])
  @@index([zoneId])
}

model Device {
  id           String       @id @default(uuid())
  floorId      String
  zoneId       String?
  code         String       @unique
  name         String
  deviceType   DeviceType
  x            Decimal      @db.Decimal(10, 2)
  y            Decimal      @db.Decimal(10, 2)
  status       DeviceStatus @default(online)
  active       Boolean      @default(true)
  metadataJson Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  floor Floor @relation(fields: [floorId], references: [id], onDelete: Cascade)
  zone  Zone? @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  @@index([floorId, active])
  @@index([zoneId])
}

model Room {
  id               String           @id @default(uuid())
  locationId       String
  floorPlanAreaId  String           @unique
  code             String           @unique
  name             String
  roomType         RoomType
  privacyLevel     RoomPrivacyLevel
  status           RoomStatus       @default(available)
  active           Boolean          @default(true)
  bookable         Boolean          @default(true)
  cleaningRequired Boolean          @default(false)
  lastTurnedAt     DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  location      Location          @relation(fields: [locationId], references: [id])
  floorPlanArea FloorPlanArea     @relation(fields: [floorPlanAreaId], references: [id])
  bookings      RoomBooking[]
  accessEvents  RoomAccessEvent[]
  cleaningTasks CleaningTask[]
  zone          Zone?

  @@index([locationId, status])
  @@index([roomType, privacyLevel])
}

model RoomBooking {
  id               String                @id @default(uuid())
  memberId         String
  roomId           String
  bookingType      RoomBookingType
  status           RoomBookingStatus
  startsAt         DateTime
  endsAt           DateTime
  sourceType       RoomBookingSourceType
  sourceReference  String?
  waitlistPriority Int                   @default(0)
  checkedInAt      DateTime?
  checkedOutAt     DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  member        Member            @relation(fields: [memberId], references: [id], onDelete: Cascade)
  room          Room              @relation(fields: [roomId], references: [id], onDelete: Cascade)
  accessEvents  RoomAccessEvent[]
  cleaningTasks CleaningTask[]

  @@index([roomId, startsAt])
  @@index([memberId, startsAt])
  @@index([status, startsAt])
}

model RoomAccessEvent {
  id               String               @id @default(uuid())
  bookingId        String?
  roomId           String
  memberId         String?
  wristbandId      String?
  decision         RoomAccessDecision
  denialReasonCode String?
  eventType        RoomAccessEventType
  occurredAt       DateTime
  sourceType       RoomAccessSourceType
  sourceReference  String?
  createdAt        DateTime             @default(now())

  booking   RoomBooking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  room      Room         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  member    Member?      @relation(fields: [memberId], references: [id], onDelete: SetNull)
  wristband Wristband?   @relation(fields: [wristbandId], references: [id], onDelete: SetNull)

  @@index([roomId, occurredAt])
  @@index([memberId, occurredAt])
}

model CleaningTask {
  id                    String             @id @default(uuid())
  roomId                String
  bookingId             String?
  taskType              CleaningTaskType
  status                CleaningTaskStatus @default(open)
  createdAt             DateTime           @default(now())
  startedAt             DateTime?
  completedAt           DateTime?
  assignedToStaffUserId String?
  notes                 String?

  room                Room         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  booking             RoomBooking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  assignedToStaffUser StaffUser?   @relation(fields: [assignedToStaffUserId], references: [id], onDelete: SetNull)

  @@index([roomId, status])
  @@index([status, createdAt])
}

model StaffAuditEvent {
  id                  String   @id
  eventType           String
  occurredAt          DateTime @default(now())
  actorStaffUserId    String
  actorEmailSnapshot  String
  actorRoleSnapshot   String
  targetStaffUserId   String?
  targetEmailSnapshot String?
  outcome             String
  reasonCode          String?
  metadataJson        Json?

  @@index([occurredAt])
  @@index([targetStaffUserId])
}

model EventPollingCursor {
  id           String   @id
  eventType    String   @unique
  lastPolledAt DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([eventType])
}

// ============================================================
// AO-OS Guest / Visit / Inventory / Folio domains
// ============================================================

enum GuestMembershipStatus {
  none
  basic
  premium
}

enum GuestRiskFlagStatus {
  clear
  flagged
  banned
}

enum VisitSourceType {
  booking
  walk_in
}

enum GuestVisitStatus {
  initiated
  awaiting_identity
  awaiting_waiver
  awaiting_payment
  ready_for_assignment
  paid_pending_assignment
  checked_in
  active
  extended
  checked_out
  cancelled
}

enum GuestBookingStatus {
  reserved
  confirmed
  checked_in
  completed
  cancelled
  no_show
}

enum GuestBookingChannel {
  web
  kiosk
  staff
}

enum CheckInChannel {
  web
  kiosk
  staff
}

enum CheckOutChannel {
  kiosk
  staff
  system
}

enum ProductType {
  locker
  room
}

enum ResourceAvailabilityStatus {
  available
  held
  occupied
  cleaning
  out_of_service
}

enum HoldScope {
  resource
  tier_pool
}

enum HoldStatus {
  active
  released
  expired
  converted
}

enum WristbandLinkStatus {
  active
  inactive
  revoked
}

enum FolioPaymentStatus {
  unpaid
  partially_paid
  paid
  failed
  refunded
  comped
}

enum PaymentTransactionType {
  authorize
  capture
  sale
  refund
  void
  comp
}

enum AccessPermissionStatus {
  granted
  revoked
}

enum AccessResult {
  granted
  denied
}

enum ActorType {
  staff
  kiosk
  system
  guest
}

enum ExceptionSeverity {
  info
  warning
  critical
}

enum ExceptionStatus {
  open
  acknowledged
  resolved
}

model Guest {
  id                String                @id @default(uuid()) @db.Uuid
  firstName         String                @map("first_name")
  lastName          String?               @map("last_name")
  phone             String?               @unique
  email             String?               @unique
  dateOfBirth       DateTime?             @map("date_of_birth") @db.Date
  preferredLanguage String                @default("en") @map("preferred_language")
  membershipStatus  GuestMembershipStatus @default(none) @map("membership_status")
  riskFlagStatus    GuestRiskFlagStatus   @default(clear) @map("risk_flag_status")
  marketingOptIn    Boolean               @default(false) @map("marketing_opt_in")
  version           Int                   @default(1)
  createdAt         DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  waivers        GuestWaiver[]
  guestBookings  GuestBooking[]
  visits         Visit[]
  wristbandLinks WristbandLink[]

  @@map("guests")
}

model GuestWaiver {
  id              String   @id @default(uuid()) @db.Uuid
  guestId         String   @map("guest_id") @db.Uuid
  waiverVersion   String   @map("waiver_version")
  acceptedChannel String   @map("accepted_channel")
  signatureText   String?  @map("signature_text")
  isCurrent       Boolean  @default(true) @map("is_current")
  acceptedAt      DateTime @default(now()) @map("accepted_at") @db.Timestamptz(6)

  guest Guest @relation(fields: [guestId], references: [id])

  @@index([guestId, isCurrent])
  @@map("guest_waivers")
}

model Tier {
  id                String      @id @default(uuid()) @db.Uuid
  productType       ProductType @map("product_type")
  code              String      @unique
  name              String
  publicDescription String?     @map("public_description")
  upgradeRank       Int         @default(0) @map("upgrade_rank")
  basePriceCents    Int         @map("base_price_cents")
  active            Boolean     @default(true)
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  durationOptions TierDurationOption[]
  resources       Resource[]
  guestBookings   GuestBooking[]
  visits          Visit[]

  @@map("tiers")
}

model TierDurationOption {
  id              String   @id @default(uuid()) @db.Uuid
  tierId          String   @map("tier_id") @db.Uuid
  durationMinutes Int      @map("duration_minutes")
  priceCents      Int      @map("price_cents")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tier Tier @relation(fields: [tierId], references: [id])

  @@map("tier_duration_options")
}

model Resource {
  id                    String                     @id @default(uuid()) @db.Uuid
  resourceType          ProductType                @map("resource_type")
  displayLabel          String                     @map("display_label")
  tierId                String                     @map("tier_id") @db.Uuid
  zoneCode              String                     @map("zone_code")
  status                ResourceAvailabilityStatus @default(available)
  cleaningBufferMinutes Int                        @default(30) @map("cleaning_buffer_minutes")
  currentVisitId        String?                    @map("current_visit_id") @db.Uuid
  version               Int                        @default(1)
  createdAt             DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)

  tier           Tier                   @relation(fields: [tierId], references: [id])
  stateHistory   ResourceStateHistory[]
  holds          ResourceHold[]
  assignedVisits Visit[]                @relation("VisitAssignedResource")
  exceptions     SystemException[]

  @@index([resourceType, status, tierId], map: "idx_resources_type_status_tier")
  @@map("resources")
}

model ResourceStateHistory {
  id              String   @id @default(uuid()) @db.Uuid
  resourceId      String   @map("resource_id") @db.Uuid
  previousStatus  String?  @map("previous_status")
  newStatus       String   @map("new_status")
  reasonCode      String?  @map("reason_code")
  reasonText      String?  @map("reason_text")
  changedByUserId String?  @map("changed_by_user_id")
  visitId         String?  @map("visit_id") @db.Uuid
  changedAt       DateTime @default(now()) @map("changed_at") @db.Timestamptz(6)

  resource Resource @relation(fields: [resourceId], references: [id])

  @@index([resourceId, changedAt(sort: Desc)], map: "idx_resource_state_history_resource_time")
  @@map("resource_state_history")
}

model ResourceHold {
  id            String     @id @default(uuid()) @db.Uuid
  resourceId    String     @map("resource_id") @db.Uuid
  visitId       String?    @map("visit_id") @db.Uuid
  holdScope     HoldScope  @map("hold_scope")
  status        HoldStatus @default(active)
  expiresAt     DateTime   @map("expires_at") @db.Timestamptz(6)
  releasedAt    DateTime?  @map("released_at") @db.Timestamptz(6)
  releaseReason String?    @map("release_reason")
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  resource Resource @relation(fields: [resourceId], references: [id])
  visit    Visit?   @relation(fields: [visitId], references: [id])

  @@index([resourceId, status, expiresAt], map: "idx_resource_holds_active")
  @@map("resource_holds")
}

model GuestBooking {
  id                  String              @id @default(uuid()) @db.Uuid
  guestId             String              @map("guest_id") @db.Uuid
  tierId              String              @map("tier_id") @db.Uuid
  bookingChannel      GuestBookingChannel @default(web) @map("booking_channel")
  productType         ProductType         @map("product_type")
  bookingDate         DateTime            @map("booking_date") @db.Date
  arrivalWindowStart  DateTime            @map("arrival_window_start") @db.Timestamptz(6)
  arrivalWindowEnd    DateTime            @map("arrival_window_end") @db.Timestamptz(6)
  durationMinutes     Int                 @map("duration_minutes")
  status              GuestBookingStatus  @default(reserved)
  quotedPriceCents    Int                 @default(0) @map("quoted_price_cents")
  paidAmountCents     Int                 @default(0) @map("paid_amount_cents")
  balanceDueCents     Int                 @default(0) @map("balance_due_cents")
  bookingCode         String              @unique @map("booking_code")
  qrToken             String?             @unique @map("qr_token")
  expectsExistingBand Boolean             @default(false) @map("expects_existing_band")
  version             Int                 @default(1)
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  guest      Guest               @relation(fields: [guestId], references: [id])
  tier       Tier                @relation(fields: [tierId], references: [id])
  addOns     GuestBookingAddOn[]
  visits     Visit[]
  exceptions SystemException[]

  @@index([guestId, status], map: "idx_guest_bookings_guest_status")
  @@index([arrivalWindowStart, status], map: "idx_guest_bookings_arrival_status")
  @@map("guest_bookings")
}

model GuestBookingAddOn {
  id              String @id @default(uuid()) @db.Uuid
  bookingId       String @map("booking_id") @db.Uuid
  addOnCode       String @map("add_on_code")
  quantity        Int    @default(1)
  unitPriceCents  Int    @default(0) @map("unit_price_cents")
  totalPriceCents Int    @default(0) @map("total_price_cents")

  booking GuestBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("guest_booking_add_ons")
}

model Visit {
  id                 String             @id @default(uuid()) @db.Uuid
  guestId            String             @map("guest_id") @db.Uuid
  bookingId          String?            @map("booking_id") @db.Uuid
  sourceType         VisitSourceType    @map("source_type")
  productType        ProductType        @map("product_type")
  tierId             String             @map("tier_id") @db.Uuid
  durationMinutes    Int                @map("duration_minutes")
  status             GuestVisitStatus   @default(initiated)
  startTime          DateTime?          @map("start_time") @db.Timestamptz(6)
  scheduledEndTime   DateTime?          @map("scheduled_end_time") @db.Timestamptz(6)
  actualEndTime      DateTime?          @map("actual_end_time") @db.Timestamptz(6)
  assignedResourceId String?            @map("assigned_resource_id") @db.Uuid
  assignedBandId     String?            @map("assigned_band_id") @db.Uuid
  waiverRequired     Boolean            @default(true) @map("waiver_required")
  waiverCompleted    Boolean            @default(false) @map("waiver_completed")
  paymentStatus      FolioPaymentStatus @default(unpaid) @map("payment_status")
  checkInChannel     CheckInChannel?    @map("check_in_channel")
  checkOutChannel    CheckOutChannel?   @map("check_out_channel")
  version            Int                @default(1)
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  guest               Guest                @relation(fields: [guestId], references: [id])
  booking             GuestBooking?        @relation(fields: [bookingId], references: [id])
  tier                Tier                 @relation(fields: [tierId], references: [id])
  assignedResource    Resource?            @relation("VisitAssignedResource", fields: [assignedResourceId], references: [id])
  statusHistory       VisitStatusHistory[]
  wristbandLinks      WristbandLink[]
  holds               ResourceHold[]
  folio               Folio?
  paymentTransactions PaymentTransaction[]
  accessPermissions   AccessPermission[]
  guestAccessEvents   GuestAccessEvent[]
  exceptions          SystemException[]

  @@index([guestId, status], map: "idx_visits_guest_status")
  @@index([status, createdAt(sort: Desc)], map: "idx_visits_status_created")
  @@map("visits")
}

model VisitStatusHistory {
  id              String   @id @default(uuid()) @db.Uuid
  visitId         String   @map("visit_id") @db.Uuid
  previousStatus  String?  @map("previous_status")
  newStatus       String   @map("new_status")
  reasonCode      String?  @map("reason_code")
  reasonText      String?  @map("reason_text")
  changedByUserId String?  @map("changed_by_user_id")
  changedAt       DateTime @default(now()) @map("changed_at") @db.Timestamptz(6)

  visit Visit @relation(fields: [visitId], references: [id])

  @@index([visitId, changedAt(sort: Desc)], map: "idx_visit_status_history_visit_time")
  @@map("visit_status_history")
}

model WristbandLink {
  id          String              @id @default(uuid()) @db.Uuid
  wristbandId String              @map("wristband_id")
  guestId     String              @map("guest_id") @db.Uuid
  visitId     String              @map("visit_id") @db.Uuid
  linkStatus  WristbandLinkStatus @default(active) @map("link_status")
  reasonCode  String?             @map("reason_code")
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  wristband Wristband @relation(fields: [wristbandId], references: [id])
  guest     Guest     @relation(fields: [guestId], references: [id])
  visit     Visit     @relation(fields: [visitId], references: [id])

  @@index([wristbandId, linkStatus], map: "idx_wristband_links_band_status")
  @@index([visitId, linkStatus], map: "idx_wristband_links_visit_status")
  @@map("wristband_links")
}

model Folio {
  id                   String             @id @default(uuid()) @db.Uuid
  visitId              String             @unique @map("visit_id") @db.Uuid
  subtotalCents        Int                @default(0) @map("subtotal_cents")
  taxesCents           Int                @default(0) @map("taxes_cents")
  feesCents            Int                @default(0) @map("fees_cents")
  wristbandChargeCents Int                @default(0) @map("wristband_charge_cents")
  addOnTotalCents      Int                @default(0) @map("add_on_total_cents")
  discountsCents       Int                @default(0) @map("discounts_cents")
  totalDueCents        Int                @default(0) @map("total_due_cents")
  amountPaidCents      Int                @default(0) @map("amount_paid_cents")
  balanceDueCents      Int                @default(0) @map("balance_due_cents")
  paymentStatus        FolioPaymentStatus @default(unpaid) @map("payment_status")
  version              Int                @default(1)
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  visit               Visit                @relation(fields: [visitId], references: [id])
  lineItems           FolioLineItem[]
  paymentTransactions PaymentTransaction[]
  exceptions          SystemException[]

  @@map("folios")
}

model FolioLineItem {
  id               String   @id @default(uuid()) @db.Uuid
  folioId          String   @map("folio_id") @db.Uuid
  lineType         String   @map("line_type")
  referenceCode    String?  @map("reference_code")
  description      String
  quantity         Int      @default(1)
  unitAmountCents  Int      @map("unit_amount_cents")
  totalAmountCents Int      @map("total_amount_cents")
  metadata         Json     @default("{}")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  folio Folio @relation(fields: [folioId], references: [id], onDelete: Cascade)

  @@map("folio_line_items")
}

model PaymentTransaction {
  id                      String                 @id @default(uuid()) @db.Uuid
  folioId                 String                 @map("folio_id") @db.Uuid
  visitId                 String                 @map("visit_id") @db.Uuid
  paymentProvider         String                 @map("payment_provider")
  providerPaymentIntentId String?                @map("provider_payment_intent_id")
  transactionType         PaymentTransactionType @map("transaction_type")
  amountCents             Int                    @map("amount_cents")
  status                  String
  cardBrand               String?                @map("card_brand")
  cardLast4               String?                @map("card_last4")
  idempotencyKey          String?                @unique(map: "uq_payment_idempotency_key") @map("idempotency_key")
  providerResponse        Json?                  @map("provider_response")
  createdAt               DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)

  folio Folio @relation(fields: [folioId], references: [id])
  visit Visit @relation(fields: [visitId], references: [id])

  @@map("payment_transactions")
}

model AccessPermission {
  id               String                 @id @default(uuid()) @db.Uuid
  wristbandId      String                 @map("wristband_id")
  visitId          String                 @map("visit_id") @db.Uuid
  zoneCode         String                 @map("zone_code")
  permissionStatus AccessPermissionStatus @default(granted) @map("permission_status")
  validFrom        DateTime               @map("valid_from") @db.Timestamptz(6)
  validUntil       DateTime               @map("valid_until") @db.Timestamptz(6)
  revokedAt        DateTime?              @map("revoked_at") @db.Timestamptz(6)
  createdAt        DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)

  wristband Wristband @relation(fields: [wristbandId], references: [id])
  visit     Visit     @relation(fields: [visitId], references: [id])

  @@index([wristbandId, zoneCode, permissionStatus], map: "idx_access_permissions_band_zone")
  @@map("access_permissions")
}

model GuestAccessEvent {
  id           String       @id @default(uuid()) @db.Uuid
  wristbandId  String?      @map("wristband_id")
  visitId      String?      @map("visit_id") @db.Uuid
  readerId     String       @map("reader_id")
  zoneCode     String       @map("zone_code")
  accessResult AccessResult @map("access_result")
  denialReason String?      @map("denial_reason")
  eventTime    DateTime     @map("event_time") @db.Timestamptz(6)
  rawPayload   Json?        @map("raw_payload")

  wristband Wristband? @relation(fields: [wristbandId], references: [id])
  visit     Visit?     @relation(fields: [visitId], references: [id])

  @@index([wristbandId, eventTime(sort: Desc)], map: "idx_guest_access_events_band_time")
  @@map("guest_access_events")
}

model AuditLog {
  id          String    @id @default(uuid()) @db.Uuid
  actorUserId String?   @map("actor_user_id")
  actorType   ActorType @map("actor_type")
  entityType  String    @map("entity_type")
  entityId    String?   @map("entity_id") @db.Uuid
  action      String
  reasonCode  String?   @map("reason_code")
  reasonText  String?   @map("reason_text")
  beforeState Json?     @map("before_state")
  afterState  Json?     @map("after_state")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([entityType, entityId, createdAt(sort: Desc)], map: "idx_audit_log_entity")
  @@map("audit_log")
}

model SystemException {
  id            String            @id @default(uuid()) @db.Uuid
  exceptionType String            @map("exception_type")
  severity      ExceptionSeverity
  visitId       String?           @map("visit_id") @db.Uuid
  bookingId     String?           @map("booking_id") @db.Uuid
  folioId       String?           @map("folio_id") @db.Uuid
  resourceId    String?           @map("resource_id") @db.Uuid
  wristbandId   String?           @map("wristband_id")
  status        ExceptionStatus   @default(open)
  payload       Json              @default("{}")
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  resolvedAt    DateTime?         @map("resolved_at") @db.Timestamptz(6)

  visit     Visit?        @relation(fields: [visitId], references: [id])
  booking   GuestBooking? @relation(fields: [bookingId], references: [id])
  folio     Folio?        @relation(fields: [folioId], references: [id])
  resource  Resource?     @relation(fields: [resourceId], references: [id])
  wristband Wristband?    @relation(fields: [wristbandId], references: [id])

  @@index([status, severity, createdAt(sort: Desc)], map: "idx_system_exceptions_status")
  @@map("system_exceptions")
}
