generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberStatus {
  pending
  active
  suspended
  banned
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  paused
  cancelled
}

enum BillingInterval {
  day
  week
  month
  year
}

enum PaymentMethodStatus {
  active
  inactive
  revoked
}

enum WristbandStatus {
  inventory
  assigned
  active
  lost
  stolen
  damaged
  retired
}

enum AccessDecision {
  allowed
  denied
  error
}

enum VisitStatus {
  checked_in
  checked_out
}

enum StaffRole {
  front_desk
  operations
  admin
}

enum WristbandTransactionType {
  purchase
  adjustment
  refund
}

enum WristbandTransactionStatus {
  pending
  completed
  failed
}

enum MemberAccountEntryType {
  charge
  credit
  refund
  payment
}

enum MemberAccountEntryStatus {
  posted
  voided
}

enum MemberAccountSourceType {
  wristband_transaction
  manual_adjustment
  manual_payment
  refund
  membership
  locker_fee
}

enum LockerStatus {
  available
  assigned
  out_of_service
}

enum LockerAccessDecision {
  allowed
  denied
}

enum LockerAccessEventType {
  unlock
  lock
  open
  close
}

enum FloorPlanAreaType {
  room
  corridor
  entry
  service
  bath
  lounge
  locker_bank
}

enum RoomType {
  private
  premium_private
  retreat
  ritual
  accessible
  couples_reserved_future
}

enum RoomPrivacyLevel {
  standard
  high
  premium
}

enum RoomStatus {
  available
  booked
  occupied
  cleaning
  out_of_service
}

enum RoomBookingType {
  restore
  release
  retreat
}

enum RoomBookingStatus {
  reserved
  checked_in
  checked_out
  expired
  cancelled
  no_show
  waitlisted
}

enum RoomBookingSourceType {
  membership_credit
  upgrade_credit
  one_time_purchase
  manual_staff
  package_credit
}

enum RoomAccessDecision {
  allowed
  denied
  error
}

enum RoomAccessEventType {
  unlock
  lock
  open
  close
  check_in_gate
  check_out_gate
}

enum RoomAccessSourceType {
  wristband_reader
  staff_console
  system
}

enum CleaningTaskType {
  turnover
  deep_clean
  inspection
}

enum CleaningTaskStatus {
  open
  in_progress
  completed
  cancelled
}

model Member {
  id                   String                   @id @default(uuid())
  publicMemberNumber   String                   @unique
  email                String                   @unique
  firstName            String
  lastName             String
  displayName          String?
  phone                String?
  status               MemberStatus             @default(pending)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  profile              MemberProfile?
  authIdentities       AuthIdentity[]
  subscriptions        MembershipSubscription[]
  paymentMethods       PaymentMethodToken[]
  wristbandAssignments WristbandAssignment[]
  visitSessions        VisitSession[]
  accessAttempts       AccessAttempt[]
  accessGrants         MemberAccessGrant[]
  accessOverrides      MemberAccessOverride[]
  presenceEvents       PresenceEvent[]
  wristbandTransactions WristbandTransaction[]
  lockerAssignments     LockerAssignment[]
  lockerAccessEvents    LockerAccessEvent[]
  accountEntries        MemberAccountEntry[]
  roomBookings          RoomBooking[]
  roomAccessEvents      RoomAccessEvent[]
}

model MemberProfile {
  id                     String   @id @default(uuid())
  memberId               String   @unique
  preferredName          String?
  pronouns               String?
  emergencyContactName   String?
  emergencyContactPhone  String?
  marketingOptInEmail    Boolean  @default(false)
  marketingOptInSms      Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  member                 Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model AuthIdentity {
  id              String   @id @default(uuid())
  memberId        String
  provider        String
  providerUserId  String
  createdAt       DateTime @default(now())

  member          Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
}

model StaffUser {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  fullName      String
  role          StaffRole @default(front_desk)
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assignedCleaningTasks CleaningTask[]
}

model MembershipPlan {
  id                String                   @id @default(uuid())
  code              String                   @unique
  name              String
  description       String?
  tierRank          Int
  billingInterval   BillingInterval
  priceAmount       Decimal                  @db.Decimal(10, 2)
  currency          String
  active            Boolean                  @default(true)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  subscriptions     MembershipSubscription[]
  entitlements      MembershipEntitlement[]
}

model MembershipSubscription {
  id                        String               @id @default(uuid())
  memberId                  String
  membershipPlanId          String
  billingProvider           String
  billingProviderCustomerId String?
  status                    SubscriptionStatus
  cancelAtPeriodEnd         Boolean              @default(false)
  startDate                 DateTime
  currentPeriodStart        DateTime?
  currentPeriodEnd          DateTime?
  pausedAt                  DateTime?
  resumedAt                 DateTime?
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt

  member                    Member               @relation(fields: [memberId], references: [id], onDelete: Cascade)
  membershipPlan            MembershipPlan       @relation(fields: [membershipPlanId], references: [id])
}

model MembershipEntitlement {
  id                String         @id @default(uuid())
  membershipPlanId  String
  entitlementCode   String
  entitlementType   String
  valueJson         Json
  active            Boolean        @default(true)
  createdAt         DateTime       @default(now())

  membershipPlan    MembershipPlan @relation(fields: [membershipPlanId], references: [id], onDelete: Cascade)
}

model PaymentMethodToken {
  id                       String               @id @default(uuid())
  memberId                 String
  provider                 String
  providerCustomerId       String?
  providerPaymentMethodId  String
  brand                    String?
  last4                    String?
  expMonth                 Int?
  expYear                  Int?
  isDefault                Boolean              @default(false)
  status                   PaymentMethodStatus  @default(active)
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt

  member                   Member               @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model Location {
  id               String         @id @default(uuid())
  code             String         @unique
  name             String
  createdAt        DateTime       @default(now())

  wristbands       Wristband[]
  accessPoints     AccessPoint[]
  visitSessions    VisitSession[]
  lockers          Locker[]
  floorPlans       FloorPlan[]
  rooms            Room[]
}

model Wristband {
  id               String                @id @default(uuid())
  uid              String                @unique
  locationId       String?
  status           WristbandStatus       @default(inventory)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  location         Location?             @relation(fields: [locationId], references: [id])
  assignments      WristbandAssignment[]
  accessAttempts   AccessAttempt[]
  wristbandTransactions WristbandTransaction[]
  lockerAccessEvents    LockerAccessEvent[]
  roomAccessEvents      RoomAccessEvent[]
}

model WristbandAssignment {
  id                    String      @id @default(uuid())
  wristbandId           String
  memberId              String
  assignedByStaffUserId String?
  assignedAt            DateTime    @default(now())
  unassignedAt          DateTime?
  unassignedReason      String?
  active                Boolean     @default(true)

  wristband             Wristband   @relation(fields: [wristbandId], references: [id], onDelete: Cascade)
  member                Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  visitSessions         VisitSession[]
  lockerAssignments     LockerAssignment[]
}

model WristbandTransaction {
  id              String                    @id @default(uuid())
  memberId        String
  wristbandId     String
  transactionType WristbandTransactionType
  merchantType    String
  amount          Decimal                   @db.Decimal(10, 2)
  currency        String
  description     String?
  sourceReference String?
  status          WristbandTransactionStatus @default(completed)
  occurredAt      DateTime
  createdAt       DateTime                  @default(now())

  member          Member                    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  wristband       Wristband                 @relation(fields: [wristbandId], references: [id], onDelete: Cascade)

  @@index([occurredAt])
  @@index([memberId])
}

model MemberAccountEntry {
  id              String                   @id @default(uuid())
  memberId        String
  entryType       MemberAccountEntryType
  amount          Decimal                  @db.Decimal(10, 2)
  currency        String
  description     String?
  status          MemberAccountEntryStatus @default(posted)
  sourceType      MemberAccountSourceType
  sourceReference String?
  occurredAt      DateTime
  createdAt       DateTime                 @default(now())

  member          Member                   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, occurredAt])
  @@index([memberId, status])
}

model Locker {
  id              String              @id @default(uuid())
  code            String              @unique
  locationId      String?
  status          LockerStatus        @default(available)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  location        Location?           @relation(fields: [locationId], references: [id])
  assignments     LockerAssignment[]
  accessEvents    LockerAccessEvent[]
}

model LockerAssignment {
  id                    String               @id @default(uuid())
  lockerId              String
  memberId              String
  wristbandAssignmentId String?
  assignedByStaffUserId String?
  assignedAt            DateTime             @default(now())
  unassignedAt          DateTime?
  unassignedReason      String?
  active                Boolean              @default(true)

  locker                Locker               @relation(fields: [lockerId], references: [id], onDelete: Cascade)
  member                Member               @relation(fields: [memberId], references: [id], onDelete: Cascade)
  wristbandAssignment   WristbandAssignment? @relation(fields: [wristbandAssignmentId], references: [id], onDelete: SetNull)
  accessEvents          LockerAccessEvent[]

  @@index([lockerId, active])
  @@index([memberId])
}

model LockerAccessEvent {
  id                 String              @id @default(uuid())
  memberId           String?
  lockerId           String
  wristbandId        String?
  lockerAssignmentId String?
  decision           LockerAccessDecision
  denialReasonCode   String?
  eventType          LockerAccessEventType
  occurredAt         DateTime
  sourceReference    String?
  createdAt          DateTime            @default(now())

  member             Member?             @relation(fields: [memberId], references: [id], onDelete: SetNull)
  locker             Locker              @relation(fields: [lockerId], references: [id], onDelete: Cascade)
  wristband          Wristband?          @relation(fields: [wristbandId], references: [id], onDelete: SetNull)
  lockerAssignment   LockerAssignment?   @relation(fields: [lockerAssignmentId], references: [id], onDelete: SetNull)

  @@index([occurredAt])
  @@index([memberId])
}

model AccessZone {
  id                 String               @id @default(uuid())
  code               String               @unique
  name               String
  requiresBooking    Boolean              @default(false)
  createdAt          DateTime             @default(now())

  accessPoints       AccessPoint[]
  accessAttempts     AccessAttempt[]
  accessGrants       MemberAccessGrant[]
  accessOverrides    MemberAccessOverride[]
  bookings           Booking[]
  presenceEvents     PresenceEvent[]
}

model AccessPoint {
  id                 String         @id @default(uuid())
  locationId         String
  accessZoneId       String
  code               String         @unique
  name               String
  createdAt          DateTime       @default(now())

  location           Location       @relation(fields: [locationId], references: [id])
  accessZone         AccessZone     @relation(fields: [accessZoneId], references: [id])
  accessAttempts     AccessAttempt[]
}

model MemberAccessGrant {
  id                 String      @id @default(uuid())
  memberId           String
  accessZoneId       String
  validFrom          DateTime?
  validUntil         DateTime?
  active             Boolean     @default(true)
  createdAt          DateTime    @default(now())

  member             Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  accessZone         AccessZone  @relation(fields: [accessZoneId], references: [id], onDelete: Cascade)
}

model MemberAccessOverride {
  id                    String      @id @default(uuid())
  memberId              String
  accessZoneId          String
  action                String
  reason                String?
  grantedByStaffUserId  String?
  validFrom             DateTime?
  validUntil            DateTime?
  createdAt             DateTime    @default(now())

  member                Member      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  accessZone            AccessZone  @relation(fields: [accessZoneId], references: [id], onDelete: Cascade)
}

model AccessAttempt {
  id                 String          @id @default(uuid())
  memberId           String?
  wristbandId        String?
  accessPointId      String
  accessZoneId       String
  attemptSource      String?
  decision           AccessDecision
  denialReasonCode   String?
  occurredAt         DateTime

  member             Member?         @relation(fields: [memberId], references: [id], onDelete: SetNull)
  wristband          Wristband?      @relation(fields: [wristbandId], references: [id], onDelete: SetNull)
  accessPoint        AccessPoint     @relation(fields: [accessPointId], references: [id])
  accessZone         AccessZone      @relation(fields: [accessZoneId], references: [id])
}

model VisitSession {
  id                    String               @id @default(uuid())
  memberId              String
  locationId            String
  wristbandAssignmentId String?
  checkInAt             DateTime
  checkOutAt            DateTime?
  status                VisitStatus
  createdAt             DateTime             @default(now())

  member                Member               @relation(fields: [memberId], references: [id], onDelete: Cascade)
  location              Location             @relation(fields: [locationId], references: [id])
  wristbandAssignment   WristbandAssignment? @relation(fields: [wristbandAssignmentId], references: [id])
  presenceEvents        PresenceEvent[]
}

model PresenceEvent {
  id                 String       @id @default(uuid())
  visitSessionId     String
  memberId           String
  accessZoneId       String?
  eventType          String
  sourceType         String?
  sourceReference    String?
  occurredAt         DateTime     @default(now())
  payloadJson        Json?

  visitSession       VisitSession @relation(fields: [visitSessionId], references: [id], onDelete: Cascade)
  member             Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  accessZone         AccessZone?  @relation(fields: [accessZoneId], references: [id], onDelete: SetNull)
}

model Booking {
  id                 String      @id @default(uuid())
  memberId           String
  accessZoneId       String
  startsAt           DateTime
  endsAt             DateTime
  status             String
  createdAt          DateTime    @default(now())

  accessZone         AccessZone  @relation(fields: [accessZoneId], references: [id])
}

model FloorPlan {
  id          String          @id @default(uuid())
  locationId  String
  name        String
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  location    Location        @relation(fields: [locationId], references: [id], onDelete: Cascade)
  areas       FloorPlanArea[]

  @@index([locationId, active])
}

model FloorPlanArea {
  id          String            @id @default(uuid())
  floorPlanId String
  code        String
  name        String
  areaType    FloorPlanAreaType
  x           Decimal           @db.Decimal(10, 2)
  y           Decimal           @db.Decimal(10, 2)
  width       Decimal           @db.Decimal(10, 2)
  height      Decimal           @db.Decimal(10, 2)
  active      Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  floorPlan   FloorPlan         @relation(fields: [floorPlanId], references: [id], onDelete: Cascade)
  room        Room?

  @@unique([floorPlanId, code])
  @@index([floorPlanId, active])
}

model Room {
  id               String           @id @default(uuid())
  locationId       String
  floorPlanAreaId  String           @unique
  code             String           @unique
  name             String
  roomType         RoomType
  privacyLevel     RoomPrivacyLevel
  status           RoomStatus       @default(available)
  active           Boolean          @default(true)
  bookable         Boolean          @default(true)
  cleaningRequired Boolean          @default(false)
  lastTurnedAt     DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  location         Location         @relation(fields: [locationId], references: [id])
  floorPlanArea    FloorPlanArea    @relation(fields: [floorPlanAreaId], references: [id])
  bookings         RoomBooking[]
  accessEvents     RoomAccessEvent[]
  cleaningTasks    CleaningTask[]

  @@index([locationId, status])
  @@index([roomType, privacyLevel])
}

model RoomBooking {
  id               String                @id @default(uuid())
  memberId         String
  roomId           String
  bookingType      RoomBookingType
  status           RoomBookingStatus
  startsAt         DateTime
  endsAt           DateTime
  sourceType       RoomBookingSourceType
  sourceReference  String?
  waitlistPriority Int                   @default(0)
  checkedInAt      DateTime?
  checkedOutAt     DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  member           Member                @relation(fields: [memberId], references: [id], onDelete: Cascade)
  room             Room                  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  accessEvents     RoomAccessEvent[]
  cleaningTasks    CleaningTask[]

  @@index([roomId, startsAt])
  @@index([memberId, startsAt])
  @@index([status, startsAt])
}

model RoomAccessEvent {
  id               String              @id @default(uuid())
  bookingId        String?
  roomId           String
  memberId         String?
  wristbandId      String?
  decision         RoomAccessDecision
  denialReasonCode String?
  eventType        RoomAccessEventType
  occurredAt       DateTime
  sourceType       RoomAccessSourceType
  sourceReference  String?
  createdAt        DateTime            @default(now())

  booking          RoomBooking?        @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  room             Room                @relation(fields: [roomId], references: [id], onDelete: Cascade)
  member           Member?             @relation(fields: [memberId], references: [id], onDelete: SetNull)
  wristband        Wristband?          @relation(fields: [wristbandId], references: [id], onDelete: SetNull)

  @@index([roomId, occurredAt])
  @@index([memberId, occurredAt])
}

model CleaningTask {
  id                    String             @id @default(uuid())
  roomId                String
  bookingId             String?
  taskType              CleaningTaskType
  status                CleaningTaskStatus @default(open)
  createdAt             DateTime           @default(now())
  startedAt             DateTime?
  completedAt           DateTime?
  assignedToStaffUserId String?
  notes                 String?

  room                  Room               @relation(fields: [roomId], references: [id], onDelete: Cascade)
  booking               RoomBooking?       @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  assignedToStaffUser   StaffUser?         @relation(fields: [assignedToStaffUserId], references: [id], onDelete: SetNull)

  @@index([roomId, status])
  @@index([status, createdAt])
}