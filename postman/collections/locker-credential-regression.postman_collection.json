{
  "info": {
    "name": "AO OS - Locker Credential Regression",
    "description": "Regression collection for credential lifecycle, locker policy, assignment/release, and hard-blocked override safety states.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000/v1" },
    { "key": "adminEmail", "value": "admin@ao-os.dev" },
    { "key": "adminPassword", "value": "AdminPass123!" },
    { "key": "siteId", "value": "aaaaaaaa-0000-0000-0000-000000000001" },
    { "key": "runTs", "value": "{{$timestamp}}" },
    { "key": "adminToken", "value": "" },
    { "key": "planId", "value": "" },
    { "key": "memberId", "value": "" },
    { "key": "subscriptionId", "value": "" },
    { "key": "credentialId", "value": "" },
    { "key": "replacementCredentialId", "value": "" },
    { "key": "sessionId", "value": "" },
    { "key": "lockerId", "value": "" },
    { "key": "maintenanceLockerId", "value": "" },
    { "key": "offlineLockerId", "value": "" },
    { "key": "forcedOpenLockerId", "value": "" },
    { "key": "outOfServiceLockerId", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('admin login returns 200/201', function () {",
                  "  pm.expect([200, 201]).to.include(pm.response.code);",
                  "});",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('adminToken', body.accessToken);",
                  "pm.test('token exists', function () {",
                  "  pm.expect(body.accessToken).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "2. Setup",
      "item": [
        {
          "name": "Create Membership Plan",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.response.to.have.status(201);",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('planId', body.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"STANDARD-{{runTs}}\",\n  \"name\": \"Standard\",\n  \"tierRank\": 1,\n  \"billingInterval\": \"month\",\n  \"priceAmount\": 4999,\n  \"currency\": \"USD\",\n  \"active\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/membership-plans"
          }
        },
        {
          "name": "Create Member",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.response.to.have.status(201);",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('memberId', body.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"regression-{{runTs}}@ao-os.test\",\n  \"firstName\": \"Regression\",\n  \"lastName\": \"Runner\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/members"
          }
        },
        {
          "name": "Create Subscription",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.response.to.have.status(201);",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('subscriptionId', body.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"memberId\": \"{{memberId}}\",\n  \"membershipPlanId\": \"{{planId}}\",\n  \"billingProvider\": \"manual\",\n  \"status\": \"active\",\n  \"startDate\": \"2026-01-01T00:00:00.000Z\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/subscriptions"
          }
        },
        {
          "name": "Create Available Locker",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.response.to.have.status(201);",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('lockerId', body.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"LK-BASE-{{runTs}}\",\n  \"locationId\": \"{{siteId}}\",\n  \"status\": \"available\",\n  \"supportsDayUse\": true,\n  \"supportsAssignedUse\": true,\n  \"active\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/lockers"
          }
        },
        {
          "name": "Create Maintenance Locker",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(201);", "pm.collectionVariables.set('maintenanceLockerId', pm.response.json().id);"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"code\": \"LK-MAINT-{{runTs}}\",\n  \"locationId\": \"{{siteId}}\",\n  \"status\": \"maintenance\",\n  \"supportsDayUse\": true,\n  \"supportsAssignedUse\": true,\n  \"active\": true\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{baseUrl}}/lockers"
          }
        },
        {
          "name": "Create Offline Locker",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(201);", "pm.collectionVariables.set('offlineLockerId', pm.response.json().id);"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"code\": \"LK-OFFLINE-{{runTs}}\",\n  \"locationId\": \"{{siteId}}\",\n  \"status\": \"offline\",\n  \"supportsDayUse\": true,\n  \"supportsAssignedUse\": true,\n  \"active\": true\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{baseUrl}}/lockers"
          }
        },
        {
          "name": "Create Forced Open Locker",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(201);", "pm.collectionVariables.set('forcedOpenLockerId', pm.response.json().id);"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"code\": \"LK-FORCED-{{runTs}}\",\n  \"locationId\": \"{{siteId}}\",\n  \"status\": \"forced_open\",\n  \"supportsDayUse\": true,\n  \"supportsAssignedUse\": true,\n  \"active\": true\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{baseUrl}}/lockers"
          }
        },
        {
          "name": "Create Out Of Service Locker",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(201);", "pm.collectionVariables.set('outOfServiceLockerId', pm.response.json().id);"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"code\": \"LK-OOS-{{runTs}}\",\n  \"locationId\": \"{{siteId}}\",\n  \"status\": \"out_of_service\",\n  \"supportsDayUse\": true,\n  \"supportsAssignedUse\": true,\n  \"active\": true\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{baseUrl}}/lockers"
          }
        },
        {
          "name": "Issue Credential",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(201);", "pm.collectionVariables.set('credentialId', pm.response.json().id);"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"uid\": \"WB-{{runTs}}\",\n  \"memberId\": \"{{memberId}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{baseUrl}}/wristbands/issue"
          }
        },
        {
          "name": "Activate Credential",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"credentialId\": \"{{credentialId}}\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{baseUrl}}/wristbands/activate"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(201);"] } }]
        },
        {
          "name": "Check In Session",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(201);", "pm.collectionVariables.set('sessionId', pm.response.json().id);"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"memberId\": \"{{memberId}}\",\n  \"locationId\": \"{{siteId}}\",\n  \"checkInAt\": \"2026-01-01T00:00:00.000Z\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{baseUrl}}/visit-sessions/check-in"
          }
        }
      ]
    },
    {
      "name": "3. Baseline Locker Flow",
      "item": [
        {
          "name": "Evaluate Policy (eligible)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(201);", "const body = pm.response.json();", "pm.test('allow/eligible', function () {", "  pm.expect(body.decision).to.eql('allow');", "  pm.expect(body.reasonCode).to.eql('LOCKER_ELIGIBLE');", "});"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"memberId\": \"{{memberId}}\",\n  \"credentialId\": \"{{credentialId}}\",\n  \"siteId\": \"{{siteId}}\",\n  \"sessionId\": \"{{sessionId}}\",\n  \"requestMode\": \"day_use_shared\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{baseUrl}}/lockers/policy/evaluate"
          }
        },
        {
          "name": "Assign Locker",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(201);"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"lockerId\": \"{{lockerId}}\",\n  \"memberId\": \"{{memberId}}\",\n  \"siteId\": \"{{siteId}}\",\n  \"visitSessionId\": \"{{sessionId}}\",\n  \"assignmentMode\": \"day_use_shared\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{baseUrl}}/lockers/assign"
          }
        },
        {
          "name": "Unassign Locker",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(201);"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"lockerId\": \"{{lockerId}}\",\n  \"unassignedReason\": \"visit_complete\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{baseUrl}}/lockers/unassign"
          }
        }
      ]
    },
    {
      "name": "4. Hard-Blocked Override Matrix",
      "item": [
        {
          "name": "Maintenance Evaluate Override -> deny LOCKER_HARD_BLOCKED_STATUS",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"memberId\": \"{{memberId}}\",\n  \"credentialId\": \"{{credentialId}}\",\n  \"siteId\": \"{{siteId}}\",\n  \"sessionId\": \"{{sessionId}}\",\n  \"requestMode\": \"staff_override\",\n  \"requestedLockerId\": \"{{maintenanceLockerId}}\",\n  \"staffOverride\": true,\n  \"staffOverrideReason\": \"Regression maintenance check\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{baseUrl}}/lockers/policy/evaluate"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(201);", "const body = pm.response.json();", "pm.expect(body.decision).to.eql('deny');", "pm.expect(body.reasonCode).to.eql('LOCKER_HARD_BLOCKED_STATUS');"] } }]
        },
        {
          "name": "Maintenance Assign Override -> 409 LOCKER_OUT_OF_SERVICE",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"lockerId\": \"{{maintenanceLockerId}}\",\n  \"memberId\": \"{{memberId}}\",\n  \"siteId\": \"{{siteId}}\",\n  \"visitSessionId\": \"{{sessionId}}\",\n  \"assignmentMode\": \"staff_override\",\n  \"staffOverrideReason\": \"Regression maintenance check\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{baseUrl}}/lockers/assign"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(409);", "const body = pm.response.json();", "pm.expect(body.message).to.eql('LOCKER_OUT_OF_SERVICE');"] } }]
        },
        {
          "name": "Offline Evaluate Override -> deny LOCKER_HARD_BLOCKED_STATUS",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"memberId\": \"{{memberId}}\",\n  \"credentialId\": \"{{credentialId}}\",\n  \"siteId\": \"{{siteId}}\",\n  \"sessionId\": \"{{sessionId}}\",\n  \"requestMode\": \"staff_override\",\n  \"requestedLockerId\": \"{{offlineLockerId}}\",\n  \"staffOverride\": true,\n  \"staffOverrideReason\": \"Regression offline check\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{baseUrl}}/lockers/policy/evaluate"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(201);", "const body = pm.response.json();", "pm.expect(body.decision).to.eql('deny');", "pm.expect(body.reasonCode).to.eql('LOCKER_HARD_BLOCKED_STATUS');"] } }]
        },
        {
          "name": "Offline Assign Override -> 409 LOCKER_OUT_OF_SERVICE",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"lockerId\": \"{{offlineLockerId}}\",\n  \"memberId\": \"{{memberId}}\",\n  \"siteId\": \"{{siteId}}\",\n  \"visitSessionId\": \"{{sessionId}}\",\n  \"assignmentMode\": \"staff_override\",\n  \"staffOverrideReason\": \"Regression offline check\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{baseUrl}}/lockers/assign"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(409);", "const body = pm.response.json();", "pm.expect(body.message).to.eql('LOCKER_OUT_OF_SERVICE');"] } }]
        },
        {
          "name": "Forced Open Evaluate Override -> deny LOCKER_HARD_BLOCKED_STATUS",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"memberId\": \"{{memberId}}\",\n  \"credentialId\": \"{{credentialId}}\",\n  \"siteId\": \"{{siteId}}\",\n  \"sessionId\": \"{{sessionId}}\",\n  \"requestMode\": \"staff_override\",\n  \"requestedLockerId\": \"{{forcedOpenLockerId}}\",\n  \"staffOverride\": true,\n  \"staffOverrideReason\": \"Regression forced_open check\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{baseUrl}}/lockers/policy/evaluate"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(201);", "const body = pm.response.json();", "pm.expect(body.decision).to.eql('deny');", "pm.expect(body.reasonCode).to.eql('LOCKER_HARD_BLOCKED_STATUS');"] } }]
        },
        {
          "name": "Forced Open Assign Override -> 409 LOCKER_OUT_OF_SERVICE",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"lockerId\": \"{{forcedOpenLockerId}}\",\n  \"memberId\": \"{{memberId}}\",\n  \"siteId\": \"{{siteId}}\",\n  \"visitSessionId\": \"{{sessionId}}\",\n  \"assignmentMode\": \"staff_override\",\n  \"staffOverrideReason\": \"Regression forced_open check\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{baseUrl}}/lockers/assign"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(409);", "const body = pm.response.json();", "pm.expect(body.message).to.eql('LOCKER_OUT_OF_SERVICE');"] } }]
        },
        {
          "name": "Out Of Service Evaluate Override -> deny LOCKER_HARD_BLOCKED_STATUS",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"memberId\": \"{{memberId}}\",\n  \"credentialId\": \"{{credentialId}}\",\n  \"siteId\": \"{{siteId}}\",\n  \"sessionId\": \"{{sessionId}}\",\n  \"requestMode\": \"staff_override\",\n  \"requestedLockerId\": \"{{outOfServiceLockerId}}\",\n  \"staffOverride\": true,\n  \"staffOverrideReason\": \"Regression out_of_service check\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{baseUrl}}/lockers/policy/evaluate"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(201);", "const body = pm.response.json();", "pm.expect(body.decision).to.eql('deny');", "pm.expect(body.reasonCode).to.eql('LOCKER_HARD_BLOCKED_STATUS');"] } }]
        },
        {
          "name": "Out Of Service Assign Override -> 409 LOCKER_OUT_OF_SERVICE",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"lockerId\": \"{{outOfServiceLockerId}}\",\n  \"memberId\": \"{{memberId}}\",\n  \"siteId\": \"{{siteId}}\",\n  \"visitSessionId\": \"{{sessionId}}\",\n  \"assignmentMode\": \"staff_override\",\n  \"staffOverrideReason\": \"Regression out_of_service check\"\n}", "options": { "raw": { "language": "json" } } },
            "url": "{{baseUrl}}/lockers/assign"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(409);", "const body = pm.response.json();", "pm.expect(body.message).to.eql('LOCKER_OUT_OF_SERVICE');"] } }]
        }
      ]
    }
  ]
}
