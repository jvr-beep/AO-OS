{
  "info": {
    "name": "AO OS - Staff Users Verification",
    "description": "Postman collection for staff-users guard verification and admin-only staff management flows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000/v1" },
    { "key": "adminEmail", "value": "admin@ao-os.dev" },
    { "key": "adminPassword", "value": "AdminPass123!" },
    { "key": "frontDeskEmail", "value": "frontdesk@ao-os.dev" },
    { "key": "frontDeskPassword", "value": "FrontDesk123!" },
    { "key": "adminToken", "value": "" },
    { "key": "frontDeskToken", "value": "" },
    { "key": "createdStaffUserId", "value": "" },
    { "key": "createdStaffUserEmail", "value": "ops2@ao-os.dev" },
    { "key": "createdStaffUserPassword", "value": "Ops12345!" },
    { "key": "resetPassword", "value": "OpsReset123!" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"admin login returns 201\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.environment.set(\"adminToken\", body.accessToken);",
                  "pm.environment.set(\"adminUserId\", body.staffUser.id);",
                  "pm.test(\"admin token exists\", function () {",
                  "  pm.expect(body.accessToken).to.be.a(\"string\").and.not.empty;",
                  "  pm.expect(body.staffUser.role).to.eql(\"admin\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Front Desk Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"front desk login returns 201\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.environment.set(\"frontDeskToken\", body.accessToken);",
                  "pm.environment.set(\"frontDeskUserId\", body.staffUser.id);",
                  "pm.test(\"front desk token exists\", function () {",
                  "  pm.expect(body.accessToken).to.be.a(\"string\").and.not.empty;",
                  "  pm.expect(body.staffUser.role).to.eql(\"front_desk\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{frontDeskEmail}}\",\n  \"password\": \"{{frontDeskPassword}}\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Staff Users - Guard Checks",
      "item": [
        {
          "name": "Staff Users - No Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"no token returns 401\", function () {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/staff-users"
          }
        },
        {
          "name": "Staff Users - Invalid Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"invalid token returns 401\", function () {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer invalid.token.value" }
            ],
            "url": "{{baseUrl}}/staff-users"
          }
        },
        {
          "name": "Staff Users - Wrong Role",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"front desk gets 403\", function () {",
                  "  pm.response.to.have.status(403);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{frontDeskToken}}" }
            ],
            "url": "{{baseUrl}}/staff-users"
          }
        },
        {
          "name": "Staff Users - Admin Success",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"admin gets 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.test(\"response is an array\", function () {",
                  "  pm.expect(body).to.be.an(\"array\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/staff-users"
          }
        }
      ]
    },
    {
      "name": "Staff Users - Admin Flows",
      "item": [
        {
          "name": "Create Staff User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"create returns 201\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.environment.set(\"createdStaffUserId\", body.id);",
                  "pm.environment.set(\"createdStaffUserEmail\", body.email);",
                  "pm.test(\"created as operations\", function () {",
                  "  pm.expect(body.role).to.eql(\"operations\");",
                  "  pm.expect(body.active).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{createdStaffUserEmail}}\",\n  \"password\": \"Ops12345!\",\n  \"fullName\": \"Ops User Two\",\n  \"role\": \"operations\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": "{{baseUrl}}/staff-users"
          }
        },
        {
          "name": "List Staff Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"list returns 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "const createdEmail = pm.environment.get(\"createdStaffUserEmail\");",
                  "pm.test(\"created user appears in list\", function () {",
                  "  pm.expect(body.some(user => user.email === createdEmail)).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/staff-users"
          }
        },
        {
          "name": "Get Staff User By Id",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"get by id returns 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.test(\"id matches created staff user\", function () {",
                  "  pm.expect(body.id).to.eql(pm.environment.get(\"createdStaffUserId\"));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/staff-users/{{createdStaffUserId}}"
          }
        },
        {
          "name": "Filter Staff Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"filter returns 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.test(\"all results match filter\", function () {",
                  "  pm.expect(body.every(user => user.role === \"front_desk\" && user.active === true)).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/staff-users?role=front_desk&active=true"
          }
        },
        {
          "name": "Change Staff User Role",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"role patch returns 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.test(\"role updated to front_desk\", function () {",
                  "  pm.expect(body.role).to.eql(\"front_desk\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"front_desk\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": "{{baseUrl}}/staff-users/{{createdStaffUserId}}/role"
          }
        },
        {
          "name": "Reset Staff User Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"password patch returns 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"{{resetPassword}}\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": "{{baseUrl}}/staff-users/{{createdStaffUserId}}/password"
          }
        },
        {
          "name": "Deactivate Staff User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"deactivate returns 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.test(\"user is inactive\", function () {",
                  "  pm.expect(body.active).to.eql(false);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/staff-users/{{createdStaffUserId}}/deactivate"
          }
        },
        {
          "name": "Reactivate Staff User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"reactivate returns 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.test(\"user is active again\", function () {",
                  "  pm.expect(body.active).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/staff-users/{{createdStaffUserId}}/reactivate"
          }
        },
        {
          "name": "Self Deactivate Guard",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"self deactivate returns 409\", function () {",
                  "  pm.response.to.have.status(409);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/staff-users/{{adminUserId}}/deactivate"
          }
        },
        {
          "name": "Last Active Admin Guard",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"last admin downgrade returns 409\", function () {",
                  "  pm.response.to.have.status(409);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"operations\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": "{{baseUrl}}/staff-users/{{adminUserId}}/role"
          }
        }
      ]
    }
  ]
}
