# ============================================================
# AO-OS API — Runtime Environment Variables
# Copy this file to .env and fill in values for your environment.
# Never commit .env to source control.
# ============================================================

# --------------- Core runtime --------------------------------
NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:4000

# --------------- Database ------------------------------------
# Primary connection URL (used by Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/ao_os_db

# Pooled connection URL — set this if your DB provider (e.g. Supabase)
# uses a separate pooler endpoint for runtime connections.
# DATABASE_POOLED_URL=postgresql://user:password@pooler.host:6543/ao_os_db

# --------------- Auth / JWT -----------------------------------
# Must be a strong, unique secret per environment.
# In production use a secrets manager (e.g. AWS Secrets Manager, Vault).
AUTH_JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING
AUTH_JWT_EXPIRES_IN=1h

# --------------- Google OAuth (optional) ---------------------
# Required only when Google login is enabled.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/v1/auth/google/callback

# --------------- Email / transactional (optional) ------------
# Required only when email features (verification, password reset) are enabled.
# EMAIL_API_KEY=your-sendgrid-or-resend-api-key
# EMAIL_FROM=no-reply@example.com

# --------------- Bootstrap / seed admin (optional) -----------
# If set, a staff admin account is created on first boot.
# Unset or leave empty to skip seeding.
# AUTH_SEED_ADMIN_EMAIL=admin@example.com
# AUTH_SEED_ADMIN_PASSWORD=change-me-strong-password
# AUTH_SEED_ADMIN_NAME=Admin User