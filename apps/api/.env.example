# AO OS API environment template
# Copy to .env for local development or to your secret manager for production.

# Runtime
NODE_ENV=production
PORT=4000

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?sslmode=require

# Auth
AUTH_JWT_SECRET=replace-with-strong-random-secret
AUTH_JWT_EXPIRES_IN=1h

# App URLs
APP_BASE_URL=https://app.aosanctuary.com
STAFF_APP_BASE_URL=https://app.aosanctuary.com

# Google OAuth
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
GOOGLE_REDIRECT_URI=https://api.aosanctuary.com/v1/auth/google/callback

# Email provider (optional but recommended)
EMAIL_PROVIDER=gmail
EMAIL_FROM=AO OS <ops@aosanctuary.com>
RESEND_API_KEY=

# Google Workspace / Gmail API email + provisioning
GOOGLE_WORKSPACE_CLIENT_EMAIL=
GOOGLE_WORKSPACE_PRIVATE_KEY=
GOOGLE_WORKSPACE_KEYLESS=false
GOOGLE_WORKSPACE_DELEGATED_USER=
GOOGLE_WORKSPACE_CUSTOMER_ID=my_customer

# Optional admin bootstrap
AUTH_SEED_ADMIN_EMAIL=
AUTH_SEED_ADMIN_PASSWORD=
AUTH_SEED_ADMIN_NAME=Seed Admin