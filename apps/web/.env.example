# AO OS Web environment template
# Copy to .env for local development or set in Vercel project environment variables.

NODE_ENV=production

# API base for server actions and API fetch helpers
API_BASE_URL=https://api.aosanctuary.com/v1

# Session encryption secret — staff portal (minimum 32 chars)
SESSION_SECRET=replace-with-32-plus-char-random-secret

# Session encryption secret — member portal (can be different from SESSION_SECRET)
MEMBER_SESSION_SECRET=replace-with-32-plus-char-random-secret

# Anonymous error reporting key — must match MONITOR_API_KEY on the API side
OPS_REPORT_KEY=replace-with-monitor-api-key-value

# Kiosk session secret (minimum 32 chars)
KIOSK_SESSION_SECRET=replace-with-32-plus-char-random-secret

# Kiosk shared secret — must match KIOSK_API_SECRET on the API side
KIOSK_API_SECRET=replace-with-strong-random-key

# Stripe publishable key — exposed to browser for Stripe Elements
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_replace-me
