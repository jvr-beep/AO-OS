# ============================================================
# AO-OS Web — Runtime Environment Variables
# Copy this file to .env.local and fill in values.
# Never commit .env.local to source control.
# ============================================================

# --------------- API connection ------------------------------
# Must match the Cloudflare Tunnel public hostname (include /v1 suffix).
# Development: http://localhost:4000/v1
# Production:  https://api.aosanctuary.com/v1
API_BASE_URL=http://localhost:4000/v1

# --------------- Session encryption -------------------------
# Must be at least 32 characters.  Use a different value per environment.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_SECURE_RANDOM_32_CHAR_STRING
