# AO OS Web — staging environment template
# Copy values into Vercel project environment variables for the staging deployment.
# Never commit real secrets. Generate SESSION_SECRET with a 32+ char random value.

NODE_ENV=production

# Staging API base (server-side fetch only)
API_BASE_URL=https://api-staging.aosanctuary.com/v1

# Public origin for the staging web app
WEB_BASE_URL=https://staging.aosanctuary.com

# Session encryption secret — generate separately per environment, 32+ chars
SESSION_SECRET=replace-with-32-plus-char-random-secret
